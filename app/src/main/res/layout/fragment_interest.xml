<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/gray_light">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_interest"
                android:layout_marginBottom="16dp"
                android:contentDescription="Interest Icon"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Interests"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select topics you're interested in"
                android:textSize="14sp"
                android:textColor="@color/gray"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose your interests"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbBusiness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Business English"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbTravel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Travel English"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbAcademic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Academic English"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbConversational"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Conversational English"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbKids"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="English for Kids"
            android:textSize="16sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveInterests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Interests"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"/>

    </LinearLayout>

</LinearLayout>